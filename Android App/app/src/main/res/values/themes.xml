<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EventReminder" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent_dim</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="colorControlNormal">@color/border</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorControlHighlight">@color/accent</item>
    </style>

    <style name="Widget.EventReminder.Button" parent="Widget.AppCompat.Button">
        <item name="android:fontFamily">@font/syne_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
</resources>
