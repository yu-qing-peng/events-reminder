page {
  --bg: #0c0c0e;
  --surface: #141418;
  --border: #232328;
  --border-bright: #3a3a44;
  --accent: #c8ff00;
  --accent-dim: #8aad00;
  --text: #e8e8f0;
  --text-muted: #6b6b7a;
  --danger: #ff4d6d;
  --success: #00e5a0;
  --font-head: 'Syne', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'DM Mono', 'Menlo', 'Monaco', monospace;
  --radius: 10px;

  background: var(--bg);
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 28rpx;
  line-height: 1.5;
}

view, text, button, input, navigator {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button {
  background: none;
  border: none;
  outline: none;
}

button::after {
  border: none;
}

input {
  outline: none;
  background: transparent;
}

.container {
  min-height: 100vh;
  background: var(--bg);
}

.btn-primary {
  background: var(--accent);
  color: #000;
  font-family: var(--font-head);
  font-weight: 700;
  border-radius: var(--radius);
}

.btn-secondary {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-muted);
  border-radius: var(--radius);
}

.field {
  margin-bottom: 28rpx;
}

.field label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  padding: 22rpx 28rpx;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 26rpx;
  transition: border-color 0.18s;
}

.input:focus {
  border-color: var(--accent);
}

.input::placeholder {
  color: var(--text-muted);
}

.msg {
  font-size: 22rpx;
  text-align: center;
  min-height: 32rpx;
  margin-top: 20rpx;
}

.msg.err {
  color: var(--danger);
}

.msg.ok {
  color: var(--success);
}