<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_surface"
    android:padding="@dimen/padding_card"
    android:layout_marginBottom="8dp">

    <!-- Status Dot -->
    <ImageView
        android:id="@+id/ivEventDot"
        android:layout_width="@dimen/dot_size"
        android:layout_height="@dimen/dot_size"
        android:background="@drawable/dot_accent"
        android:layout_marginEnd="12dp" />

    <!-- Event Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:fontFamily="@font/syne_semibold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvEventTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.04"
            android:fontFamily="@font/dm_mono"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Countdown -->
    <TextView
        android:id="@+id/tvEventCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="10sp"
        android:fontFamily="@font/dm_mono"
        android:textStyle="bold"
        android:layout_marginEnd="8dp" />

    <!-- Delete Button -->
    <TextView
        android:id="@+id/btnDeleteEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="×"
        android:textColor="@color/border_bright"
        android:textSize="15sp"
        android:padding="4dp"
        android:gravity="center" />

</LinearLayout>
