<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.MainActivity">

    <!-- Titlebar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/titlebar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="◈ Event Reminder"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/syne_bold"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnMinimize"
                android:layout_width="@dimen/win_btn_size"
                android:layout_height="@dimen/win_btn_size"
                android:background="@drawable/dot_muted"
                android:layout_marginEnd="4dp"
                android:contentDescription="Minimize" />

            <ImageView
                android:id="@+id/btnClose"
                android:layout_width="@dimen/win_btn_size"
                android:layout_height="@dimen/win_btn_size"
                android:background="@drawable/dot_danger"
                android:contentDescription="Close" />
        </LinearLayout>
    </LinearLayout>

    <!-- App content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_screen">

            <!-- App Header with User Pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/your_events"
                    android:textColor="@color/text"
                    android:textSize="18sp"
                    android:fontFamily="@font/syne_bold"
                    android:textStyle="bold" />

                <!-- User Pill -->
                <LinearLayout
                    android:id="@+id/pillUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pill"
                    android:paddingStart="8dp"
                    android:paddingEnd="12dp"
                    android:paddingVertical="5dp">

                    <TextView
                        android:id="@+id/tvUserAvatar"
                        android:layout_width="@dimen/avatar_size"
                        android:layout_height="@dimen/avatar_size"
                        android:gravity="center"
                        android:background="@drawable/bg_accent_btn"
                        android:textColor="@color/black"
                        android:textSize="10sp"
                        android:fontFamily="@font/syne_bold"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:fontFamily="@font/dm_mono" />

                    <TextView
                        android:id="@+id/btnLogout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="× out"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:paddingStart="8dp"
                        android:fontFamily="@font/dm_mono" />
                </LinearLayout>
            </LinearLayout>

            <!-- Add Event Form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_event"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:fontFamily="@font/syne_bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etEventTitle"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="11dp"
                    android:background="@drawable/selector_input"
                    android:hint="@string/event_title_hint"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_mono"
                    android:layout_marginBottom="8dp"
                    android:inputType="text"
                    android:importantForAutofill="no" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etEventDate"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/selector_input"
                        android:textColor="@color/text"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_mono"
                        android:inputType="none"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:importantForAutofill="no" />

                    <EditText
                        android:id="@+id/etEventNote"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/selector_input"
                        android:hint="@string/note_hint"
                        android:textColorHint="@color/text_muted"
                        android:textColor="@color/text"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_mono"
                        android:inputType="text"
                        android:importantForAutofill="no" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnAddEvent"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_dashed_btn"
                    android:text="@string/add_event"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="@font/dm_mono"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Events Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upcoming"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:fontFamily="@font/dm_mono"
                android:layout_marginBottom="10dp" />

            <!-- Events Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x25CC;"
                    android:textColor="@color/text_muted"
                    android:textSize="28sp"
                    android:alpha="0.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_events"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/dm_mono"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Events List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
