.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
}

.auth-screen {
  width: 100%;
}

.auth-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-family: var(--font-head);
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 48rpx;
}

.title {
  font-family: var(--font-head);
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 12rpx;
}

.title .accent {
  color: var(--accent);
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.tabs {
  display: flex;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 6rpx;
  margin-bottom: 48rpx;
}

.tab-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.06em;
  border-radius: 8rpx;
  transition: all 0.18s;
}

.tab-btn.active {
  background: var(--accent);
  color: #000;
  font-weight: 500;
}

.form {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 40rpx;
}

.submit-btn {
  width: 100%;
  padding: 26rpx;
  margin-top: 16rpx;
  background: var(--accent);
  border: none;
  border-radius: var(--radius);
  color: #000;
  font-family: var(--font-head);
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  transition: opacity 0.18s;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn[disabled] {
  opacity: 0.4;
}

.server-section {
  margin-bottom: 48rpx;
}

.server-section .label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.server-section .label-row label {
  font-size: 20rpx;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.server-section .label-row .port-hint {
  font-size: 18rpx;
  color: var(--text-muted);
  opacity: 0.6;
}

.server-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.server-row .input {
  flex: 1;
  font-size: 24rpx;
  padding: 22rpx 28rpx;
}

.test-btn {
  flex-shrink: 0;
  padding: 22rpx 32rpx;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 22rpx;
  line-height: 1;
  transition: all 0.18s;
  white-space: nowrap;
}

.test-btn:active {
  border-color: var(--border-bright);
  color: var(--text);
}

.test-btn.testing {
  opacity: 0.5;
}

.server-status {
  font-size: 20rpx;
  margin-top: 12rpx;
  min-height: 28rpx;
}

.server-status.ok {
  color: var(--success);
}

.server-status.err {
  color: var(--danger);
}