<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".ui.LoginActivity">

    <!-- Titlebar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/titlebar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="◈ Event Reminder"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/syne_bold"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="@dimen/win_btn_size"
            android:layout_height="@dimen/win_btn_size"
            android:background="@drawable/dot_danger"
            android:contentDescription="Close" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/padding_screen">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Auth Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome\n"
                    android:textColor="@color/text"
                    android:textSize="26sp"
                    android:fontFamily="@font/syne_bold"
                    android:textStyle="bold"
                    android:lineSpacingExtra="0dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back."
                        android:textColor="@color/accent"
                        android:textSize="26sp"
                        android:fontFamily="@font/syne_bold"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/server_connect_hint"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/dm_mono" />
            </LinearLayout>

            <!-- Server IP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/server_ip"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_mono" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etServerIp"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/selector_input"
                        android:hint="192.168.1.x"
                        android:textColorHint="@color/text_muted"
                        android:textColor="@color/text"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_mono"
                        android:inputType="textVisiblePassword"
                        android:importantForAutofill="no" />

                    <Button
                        android:id="@+id/btnTestServer"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_surface"
                        android:text="@string/test"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:fontFamily="@font/dm_mono"
                        android:paddingHorizontal="14dp"
                        android:gravity="center" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvServerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:minHeight="14dp"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/dm_mono" />
            </LinearLayout>

            <!-- Login / Register Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_surface_no_border"
                android:padding="3dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tabLogin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_tab_active"
                    android:text="@string/login"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:fontFamily="@font/dm_mono" />

                <TextView
                    android:id="@+id/tabRegister"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:text="@string/register"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:fontFamily="@font/dm_mono" />
            </LinearLayout>

            <!-- Username -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/username"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/dm_mono" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/selector_input"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_mono"
                    android:inputType="text"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <!-- Password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/password"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/dm_mono" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/selector_input"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_mono"
                    android:inputType="textPassword"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <!-- Submit Button -->
            <Button
                android:id="@+id/btnAuth"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_accent_btn"
                android:text="@string/sign_in"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:fontFamily="@font/syne_bold"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:stateListAnimator="@null" />

            <!-- Message -->
            <TextView
                android:id="@+id/tvAuthMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:minHeight="16dp"
                android:fontFamily="@font/dm_mono" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
